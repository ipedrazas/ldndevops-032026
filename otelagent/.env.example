# Required
ANTHROPIC_API_KEY=sk-ant-...

# Agent settings (all optional, shown with defaults)
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_TURNS=50
MAX_COST=5.00
MAX_TOOL_CALLS=200
LOG_LEVEL=info

# Server mode only (required when running `otelagent serve`)
GITHUB_TOKEN=ghp_...
WEBHOOK_SECRET=your-webhook-secret
ALLOWED_REPOS=myorg/*,my-other-org/pulse-*
PORT=3000
